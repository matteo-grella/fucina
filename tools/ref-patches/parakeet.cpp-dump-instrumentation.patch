diff --git a/src/dump.cpp b/src/dump.cpp
new file mode 100644
index 0000000..25b489e
--- /dev/null
+++ b/src/dump.cpp
@@ -0,0 +1,53 @@
+#include "dump.hpp"
+#include <cstdio>
+#include <cstdlib>
+#include <sys/stat.h>
+
+namespace pk {
+
+const std::string& dump_dir() {
+    // C++11 guarantees thread-safe one-time init of function-local statics.
+    static const std::string dir = [] {
+        const char* e = std::getenv("PARAKEET_DUMP_DIR");
+        std::string d = (e && *e) ? std::string(e) : std::string();
+        if (!d.empty()) {
+            // Best-effort single-level create; ignore EEXIST / failures (a bad
+            // path just makes the later fopen() fail and dumps are skipped).
+            ::mkdir(d.c_str(), 0777);
+        }
+        return d;
+    }();
+    return dir;
+}
+
+namespace {
+// Write the PKD1 header + raw little-endian payload. `dtype`: 0=f32, 1=i32.
+void write_pkd(const char* name, int dtype, const int32_t* dims, int ndim,
+               const void* data, size_t nbytes) {
+    if (!dump_enabled()) return;
+    std::string path = dump_dir() + "/" + name + ".pkd";
+    std::FILE* f = std::fopen(path.c_str(), "wb");
+    if (!f) return;
+    const unsigned char magic[4] = {'P', 'K', 'D', '1'};
+    std::fwrite(magic, 1, 4, f);
+    std::fwrite(&dtype, sizeof(int32_t), 1, f);
+    std::fwrite(&ndim, sizeof(int32_t), 1, f);
+    std::fwrite(dims, sizeof(int32_t), (size_t)ndim, f);
+    if (nbytes) std::fwrite(data, 1, nbytes, f);
+    std::fclose(f);
+}
+} // namespace
+
+void dump_f32_2d(const char* name, const float* data, int rows, int cols) {
+    if (!dump_enabled()) return;
+    const int32_t dims[2] = {rows, cols};
+    write_pkd(name, /*dtype=*/0, dims, 2, data, (size_t)rows * cols * sizeof(float));
+}
+
+void dump_i32_1d(const char* name, const int32_t* data, int n) {
+    if (!dump_enabled()) return;
+    const int32_t dims[1] = {n};
+    write_pkd(name, /*dtype=*/1, dims, 1, data, (size_t)n * sizeof(int32_t));
+}
+
+} // namespace pk
diff --git a/src/dump.hpp b/src/dump.hpp
new file mode 100644
index 0000000..f1e2620
--- /dev/null
+++ b/src/dump.hpp
@@ -0,0 +1,33 @@
+#pragma once
+// Parity-dump helper (Fucina port). getenv("PARAKEET_DUMP_DIR")-gated: when that
+// env var is set, the transcription pipeline writes intermediate tensors (mel,
+// encoder output, per-step logits) and the decoded token ids to small
+// self-describing binary files so a reimplementation can be checked stage by
+// stage. No effect (zero overhead beyond one getenv) when the var is unset.
+//
+// File format "PKD1" (little-endian; Apple Silicon / x86-64 are native LE):
+//   off  bytes        field
+//   0    4            magic  = {'P','K','D','1'}
+//   4    4 (int32)    dtype  = 0 (f32) | 1 (i32)
+//   8    4 (int32)    ndim   = 1 or 2
+//   12   4*ndim int32 dims[] slowest-varying first (rows, then cols)
+//   ...  n*esz        data   row-major contiguous (esz = 4)
+#include <cstdint>
+#include <string>
+
+namespace pk {
+
+// Cached once per process from getenv("PARAKEET_DUMP_DIR"). Empty => disabled.
+// Creates the directory (best-effort mkdir) on first enabled access.
+const std::string& dump_dir();
+inline bool dump_enabled() { return !dump_dir().empty(); }
+
+// Write a 2-D f32 tensor as PKD1 to <dump_dir>/<name>.pkd. `rows` is the
+// slowest-varying dim (dim0), `cols` the fastest (dim1); `data` must be
+// contiguous row-major with rows*cols elements. No-op when disabled.
+void dump_f32_2d(const char* name, const float* data, int rows, int cols);
+
+// Write a 1-D i32 vector (e.g. decoded token ids) as PKD1. No-op when disabled.
+void dump_i32_1d(const char* name, const int32_t* data, int n);
+
+} // namespace pk
